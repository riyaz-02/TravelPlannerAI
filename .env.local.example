# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_here_run_openssl_rand_base64_32

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/travel-planner?retryWrites=true&w=majority

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here

# OpenRouteService
OPENROUTE_API_KEY=your_openroute_api_key_here

# GNews
GNEWS_API_KEY=your_gnews_api_key_here
